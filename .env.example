# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Optional under Socket Mode; required if you switch to Events API.
SLACK_SIGNING_SECRET=

# Runner selection: claude | opencode | opencode-sdk | codex-app-server
RUNNER_PROVIDER=opencode

# Claude Code
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_MS=300000
# Leave unset to use Claude Code's default model.
# CLAUDE_MODEL=claude-opus-4-7
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_STRICT_MCP=true
CLAUDE_SETTING_SOURCES=project
CLAUDE_APPROVAL_ENABLED=true
# Must remain below SESSION_IDLE_TIMEOUT_MS so an approval can default-deny cleanly.
CLAUDE_APPROVAL_TIMEOUT_MS=240000
# Optional per-turn spend cap passed through as --max-budget-usd.
# CLAUDE_MAX_BUDGET_USD=5
CLAUDE_BASELINE_PROMPT_ENABLED=true
DEFAULT_CLAUDE_DRIVER=headless
TMUX_IDLE_TTL_MS=14400000
TMUX_SWEEP_INTERVAL_MS=900000

# OpenCode / OpenCode SDK
# OPENCODE_MODEL=
OPENCODE_TIMEOUT_MS=300000
OPENCODE_CONTINUITY_ENABLED=false
JUNIOR_OPENCODE_PERMISSION=allow
OPENCODE_MCP_ENABLED=true
OPENCODE_SLACK_MCP_ENABLED=true
OPENCODE_PLAYWRIGHT_MCP_ENABLED=true
OPENCODE_MIXPANEL_MCP_ENABLED=true
OPENCODE_MONGODB_MCP_ENABLED=true
# Optional OpenCode SDK binary override.
# OPENCODE_BIN=~/.opencode/bin/opencode

# Codex app-server
CODEX_MODE=app-server
# CODEX_MODEL=
CODEX_TIMEOUT_MS=300000
CODEX_ASK_FOR_APPROVAL=never
CODEX_SANDBOX=workspace-write
CODEX_SEARCH_ENABLED=false
CODEX_APP_SERVER_CONTINUITY_ENABLED=false
CODEX_MCP_ENABLED=true
CODEX_SLACK_MCP_ENABLED=true
CODEX_PLAYWRIGHT_MCP_ENABLED=true
CODEX_MIXPANEL_MCP_ENABLED=true
CODEX_MONGODB_MCP_ENABLED=true
CODEX_MEMORY_MCP_ENABLED=true
CODEX_ISOLATED_HOME_PATH=data/codex-home
# Optional binary and source-auth-home overrides.
# CODEX_BIN=codex
# CODEX_REAL_HOME=~/.codex

# Repositories (JSON array). Optional fields: worktreeSetupCommand, devCommand,
# devPort, and readyUrl.
REPOS=[{"name":"example-backend","path":"~/Projects/example-backend","defaultBase":"origin/main"},{"name":"example-frontend","path":"~/Projects/example-frontend","defaultBase":"origin/main"}]

# Channel defaults (JSON object: channelId -> {agentType}). Listed channels
# auto-trigger Junior on every message without requiring an @mention.
CHANNEL_DEFAULTS={"C05557KKV37":{"agentType":"lead"}}
# In production, restrict elevated commands to one Slack user ID.
# ADMIN_SLACK_USER_ID=U0123456789

# Session persistence and lifecycle
SESSION_STALE_TIMEOUT_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=900000
# sqlite (persisted) or memory (tests/dev)
SESSION_STORE=sqlite
SESSION_DB_PATH=data/sessions.db
HOME_WINDOW_MS=172800000
# quiet | normal | verbose
SESSION_DEFAULT_VERBOSITY=normal
# Headless runners are interrupted and resumed after this idle interval.
SESSION_IDLE_TIMEOUT_MS=300000
SESSION_MAX_IDLE_INTERRUPTS=3
THREAD_ARCHIVE_DIR=data/thread-archives

# Associative memory
MEMORY_DB_PATH=data/memory.db
# local (production ONNX embeddings) or hashing (deterministic tests)
MEMORY_EMBED_PROVIDER=local

# Automatic recall before every incoming Slack runner turn. This costs one
# cheap model subprocess per turn; failures and timeouts fail open without recall.
# Disabled by default; enable only after verifying the extra process/latency cost.
PRE_RECALL_ENABLED=false
PRE_RECALL_RUNNER=claude
PRE_RECALL_TIMEOUT_MS=15000
# Leave unset to use the pinned cheap model for the selected runner.
# PRE_RECALL_MODEL=claude-haiku-4-5-20251001

# Localhost dashboard. Leave unset to disable.
# HTTP_DASHBOARD_PORT=3457

# Junior MCP server
MCP_PORT=3456
# Optional endpoint overrides; defaults derive from MCP_PORT.
# SLACK_MCP_URL=http://localhost:3456/mcp
# MONGODB_MCP_URL=http://localhost:3456/mcp/mongodb
# Optional stable HMAC secret for signed MCP run context. When unset, Junior
# generates a process-local secret. It is never passed to child runners.
# Generate a stable value once with: openssl rand -hex 32
# MCP_CONTEXT_SECRET=

# MongoDB MCP server. Use read-only credentials.
MDB_MCP_CONNECTION_STRING=mongodb+srv://<readonly-user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_MCP_PROXY_IDLE_TTL_MS=600000
MONGODB_MCP_PROXY_REQUEST_TIMEOUT_MS=120000

# WhatsApp message archive (read-only; exposed via whatsapp_* MCP tools).
# Pair once with: bun run src/whatsapp/pair.ts
WHATSAPP_ENABLED=false
WHATSAPP_DB_PATH=data/whatsapp.db
WHATSAPP_AUTH_DIR=data/whatsapp-auth
# Optional case-insensitive regex over group subjects; unset ingests all groups.
# WHATSAPP_GROUP_PATTERN=

# Durable product and bug pipelines. Controllers require active mode.
PIPELINE_RUNTIME_MODE=off
PIPELINE_LEGACY_DIRECTIVES_ENABLED=true
BUG_PIPELINE_ENABLED=false
PRODUCT_PIPELINE_ENABLED=false
PIPELINE_RETENTION_DAYS=90

# Outbound GitHub PR reconciliation for laptop-hosted Junior.
GITHUB_RECONCILE_ENABLED=false
GITHUB_EVENT_WAKE_ENABLED=false
GITHUB_RECONCILE_INTERVAL_MS=30000
# Recommended: a fine-grained read-only token restricted to Junior's repos.
# GITHUB_RECONCILE_TOKEN=github_pat_...
# Development-only alternative: use the account selected by `gh auth status`.
GITHUB_RECONCILE_USE_CLI=false

# Support pipeline storage override.
JUNIOR_BUG_ROOT=support/bugs

# Optional Codex app-server smoke-script overrides. These are read only by
# scripts/codex-app-server-smoke.mjs, not by the Junior service.
# CODEX_APP_SMOKE_TIMEOUT_MS=120000
# CODEX_APP_SMOKE_DISABLE_HOOKS=true
# CODEX_APP_SMOKE_MODEL=
# CODEX_APP_SMOKE_IMAGE_PATH=/absolute/path/to/image.png
# CODEX_APP_SMOKE_SLACK_CHANNEL_ID=C0123456789
# CODEX_APP_SMOKE_SLACK_TEXT=Junior Codex smoke test
