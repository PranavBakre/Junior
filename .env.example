# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Optional under Socket Mode; required if you ever switch to Events API.
SLACK_SIGNING_SECRET=

# Claude Code
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_MS=300000
# Optional. Pass through to `claude -p --model`. Leave unset to use Claude Code's default.
# CLAUDE_MODEL=claude-opus-4-7
CLAUDE_PERMISSION_MODE=bypassPermissions

# Repos (JSON array)
REPOS=[{"name":"example-backend","path":"~/Projects/example-backend","defaultBase":"origin/main"},{"name":"example-frontend","path":"~/Projects/example-frontend","defaultBase":"origin/main"}]

# Channel defaults (JSON object: channelId -> {agentType})
# Listed channels also auto-trigger Junior on every message (no @mention required).
CHANNEL_DEFAULTS={"C05557KKV37":{"agentType":"lead"}}

# Session
SESSION_STALE_TIMEOUT_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=900000
# sqlite (default, persisted) or memory (tests/dev)
SESSION_STORE=sqlite
SESSION_DB_PATH=data/sessions.db
# Home tab shows sessions active in this window. 2 days default.
HOME_WINDOW_MS=172800000
# quiet | normal | verbose
SESSION_DEFAULT_VERBOSITY=normal

# Localhost dashboard. Unset to disable.
# HTTP_DASHBOARD_PORT=3457

# Daily PR/commit worklog. Posts to Slack and writes docs/worklog/YYYY-MM-DD.md.
# WORKLOG_CRON_ENABLED=false
# WORKLOG_SLACK_CHANNEL=C0123456789
# WORKLOG_SLACK_THREAD_TS=1234567890.123456
# WORKLOG_DAILY_AT=18:00
# WORKLOG_LOOKBACK_HOURS=24
# WORKLOG_DOCS_DIR=docs/worklog
# WORKLOG_GIT_AUTHOR=you@example.com
# WORKLOG_GITHUB_USER=your-github-login
# WORKLOG_USE_AGENT=true
# WORKLOG_RUN_ON_STARTUP=false

# Slack-bot MCP server (used by spawned Claude sessions to post back to threads).
MCP_PORT=3456

# MongoDB MCP server (used only by DB-enabled agents; keep read-only credentials here).
MDB_MCP_CONNECTION_STRING=mongodb+srv://<readonly-user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
