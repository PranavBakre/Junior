{
  "name": "junior",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "cleanup": "bun run src/lifecycle/cleanup.ts",
    "memory:eval": "bun run src/memory/eval/run.ts",
    "memory:eval:real": "bun run src/memory/eval/real.ts",
    "migrate:prune-routing-logs": "bun run src/memory/migrations/2026-06-13-prune-routing-decision-logs.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.70",
    "@slack/bolt": "^4.3.0",
    "cron-parser": "^5.5.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.8.0"
  }
}
